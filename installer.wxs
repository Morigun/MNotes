<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="MNotes"
    Manufacturer="MNotes"
    Version="1.1.0"
    UpgradeCode="8f6c2d1a-4e7b-4a3f-9d2c-5b8e1f6a3c7d"
    Scope="perMachine"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of MNotes is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />

    <Icon Id="AppIcon" SourceFile="MainApp\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <Property Id="ARPURLINFOABOUT" Value="https://github.com/user/MNotes" />

    <Feature Id="MainFeature" Title="MNotes" Level="1">
      <ComponentGroupRef Id="AppComponents" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="MNotes" />
    </StandardDirectory>

    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExe">
        <File Id="MNotesExe" Source="MainApp\dist\MNotes.exe" KeyPath="yes">
          <Shortcut
            Id="StartMenuShortcut"
            Directory="ProgramMenuFolder"
            Name="MNotes"
            Description="MNotes - Note Manager"
            WorkingDirectory="INSTALLFOLDER"
            Icon="AppIcon" />
          <Shortcut
            Id="DesktopShortcut"
            Directory="DesktopFolder"
            Name="MNotes"
            Description="MNotes - Note Manager"
            WorkingDirectory="INSTALLFOLDER"
            Icon="AppIcon" />
        </File>
      </Component>
      <Component Id="AppIconFile">
        <File Id="IconFile" Source="MainApp\app.ico" />
      </Component>
    </ComponentGroup>

  </Package>
</Wix>
